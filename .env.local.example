# Bolospot API (server-side only — all client calls proxy through Next.js API routes)
BOLO_API_KEY=bolo_live_...
BOLO_API_URL=https://api.bolospot.com

# World ID
NEXT_PUBLIC_WORLD_APP_ID=app_...
NEXT_PUBLIC_WORLD_ACTION=verify-patient
WLD_API_KEY=sk_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo mode (optional — fallback credentials when World App is not installed)
DEMO_PATIENT_EMAIL=demo.patient@bomed.ai
DEMO_PATIENT_PASSWORD=
